{
  "expo": {
    "name": "FoodExpress",
    "slug": "kshitij-kamble",
    "scheme": "com.foodexpress.customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#D62F20"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.foodexpress.customer",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.foodexpress.customer"
            },
            {
              "scheme": "com.googleusercontent.apps.215877724329-gnhr3a98ejcqq98sv5sphc8m6i62r3b"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {},
    "plugins": [
      "expo-asset",
      "expo-splash-screen",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "90f671bf-ace0-4c70-9b0c-f1ac55a5d47d"
      }
    },
    "owner": "kshitij28s-team"
  }
}
